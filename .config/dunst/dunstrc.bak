[global]
    monitor = 0
    follow = keyboard
    width = (250, 500)
    height = (0, 750)
    offset = (17, 26)
    padding = 5
    horizontal_padding = 5
    gap_size = 3
    transparency = 0
    frame_width = 3
    frame_color="#a46786"
    font = Proggy 12
    corner_radius = 0
    min_icon_size = 32
    max_icon_size = 32
    format = "<b>%s</b>\n%b"

[urgency_low]
    timeout = 3

[urgency_normal]
    timeout = 5

[urgency_critical]
    timeout = 15
